# Copy to .env and fill in. Never commit .env.

# LiveKit (from your LiveKit Cloud project, or the local dev server)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Model providers
OPENAI_API_KEY=

# Optional alternates
# DEEPGRAM_API_KEY=
# CARTESIA_API_KEY=
# ELEVEN_API_KEY=
